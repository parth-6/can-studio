{
  "name": "can-studio",
  "displayName": "CAN Studio",
  "description": "CAN database editor and bus connectivity tools for VS Code",
  "version": "0.2.0",
  "publisher": "afri-bit",
  "repository": {
    "type": "git",
    "url": "https://github.com/parth-6/can-studio.git"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "bugs": {
    "url": "https://github.com/parth-6/can-studio/issues"
  },
  "homepage": "https://github.com/parth-6/can-studio",
  "keywords": [
    "dbc",
    "can",
    "can-bus",
    "can-communication",
    "can-network",
    "candb",
    "can-database",
    "automotive",
    "embedded",
    "socketcan",
    "bus-monitor",
    "signals",
    "frames",
    "ecu",
    "vehicle",
    "diagnostics"
  ],
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "icon": "resources/can-studio-logo.png",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onCommand:can-studio.openDatabase",
    "onCommand:can-studio.connectBus",
    "onCommand:can-studio.disconnectBus",
    "onCommand:can-studio.startMonitor",
    "onCommand:can-studio.stopMonitor",
    "onCommand:can-studio.transmitMessage",
    "onCommand:can-studio.openSignalLab",
    "onCommand:can-studio.closeSignalLab",
    "onCustomEditor:can-studio.canDatabaseEditor",
    "onView:can-studio.canDatabaseExplorer"
  ],
  "contributes": {
    "languages": [
      {
        "id": "dbc",
        "aliases": [
          "DBC",
          "CAN Database"
        ],
        "extensions": [
          ".dbc"
        ]
      }
    ],
    "grammars": [
      {
        "language": "dbc",
        "scopeName": "source.dbc",
        "path": "./syntaxes/dbc.tmLanguage.json"
      }
    ],
    "customEditors": [
      {
        "viewType": "can-studio.canDatabaseEditor",
        "displayName": "CAN Database Editor",
        "icon": "resources/can-studio-icon.png",
        "selector": [
          {
            "filenamePattern": "*.dbc"
          }
        ],
        "priority": "default"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "canbus-explorer",
          "title": "CAN Studio",
          "icon": "resources/can-studio-icon.png"
        }
      ]
    },
    "views": {
      "canbus-explorer": [
        {
          "id": "can-studio.canDatabaseExplorer",
          "name": "CAN Database"
        }
      ]
    },
    "commands": [
      {
        "command": "can-studio.openDatabase",
        "title": "Open CAN Database",
        "category": "CAN Studio"
      },
      {
        "command": "can-studio.openSignalLab",
        "title": "Open CAN Signal Lab",
        "category": "CAN Studio"
      },
      {
        "command": "can-studio.closeSignalLab",
        "title": "Close CAN Signal Lab…",
        "category": "CAN Studio"
      },
      {
        "command": "can-studio.connectBus",
        "title": "Connect to CAN Bus",
        "category": "CAN Studio"
      },
      {
        "command": "can-studio.disconnectBus",
        "title": "Disconnect from CAN Bus",
        "category": "CAN Studio"
      },
      {
        "command": "can-studio.startMonitor",
        "title": "Start CAN Monitor",
        "category": "CAN Studio"
      },
      {
        "command": "can-studio.stopMonitor",
        "title": "Stop CAN Monitor",
        "category": "CAN Studio"
      },
      {
        "command": "can-studio.transmitMessage",
        "title": "Transmit CAN Message",
        "category": "CAN Studio"
      }
    ],
    "configuration": {
      "title": "CAN Studio",
      "properties": {
        "can-studio.explorer.showOverallView": {
          "type": "boolean",
          "default": false,
          "description": "Show the Overall View sidebar in the DBC editor by default."
        }
      }
    }
  },
  "scripts": {
    "build:webview": "npm run build --prefix webview-ui",
    "compile": "npm run build:webview && webpack",
    "watch": "webpack --watch",
    "rebuild:native": "electron-rebuild -f -w usb,@serialport/bindings-cpp -v 30.5.1 --msvs_version=2022",
    "package": "npm run build:webview && webpack --mode production --devtool hidden-source-map",
    "package:prod": "npm run build:webview && npm run webpack:prod",
    "webpack:prod": "webpack --mode production --devtool hidden-source-map",
    "vsix": "vsce package",
    "install:dev": "npm install",
    "install:prod": "npm install --omit=dev",
    "clean": "rmdir /s /q node_modules 2>nul || true",
    "prepare:dev": "npm run clean && npm run install:dev",
    "prepare:prod": "npm run clean && npm run install:prod",
    "package:full": "npm run prepare:dev && npm run package && npm run vsix && npm run prepare:prod",
    "compile-tests": "tsc -p ./tsconfig.test.json --outDir out",
    "watch-tests": "tsc -p ./tsconfig.test.json -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\" \"webview-ui/**/*.{ts,svelte,css,js}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"webview-ui/**/*.{ts,svelte,css,js}\"",
    "test": "vscode-test",
    "test:unit": "node -e \"require('fs').rmSync('out',{recursive:true,force:true})\" && npm run compile-tests && mocha --exit --ui tdd --require ./test/mocha-vscode-stub.cjs \"out/test/unit/**/*.test.js\"",
    "test:unit:parser": "npm run compile-tests && mocha --exit --ui tdd --require ./test/mocha-vscode-stub.cjs \"out/test/unit/infrastructure/parsers/**/*.test.js\"",
    "test:integration": "npm run compile && npm run compile-tests && cross-env VSCODE_TEST_FILES=out/test/integration/**/*.test.js vscode-test"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.2",
    "mocha": "^11.3.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "webpack": "^5.104.1",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@types/serialport": "^8.0.5",
    "serialport": "^13.0.0"
  },
  "bundledDependencies": ["serialport", "@serialport/bindings-cpp", "usb"]
}
